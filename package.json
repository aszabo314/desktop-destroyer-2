{
  "name": "desktop-destroyer",
  "version": "1.0.0",
  "description": "Shoot your desktop with satisfying explosions",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac dmg",
    "build:linux": "electron-builder --linux AppImage",
    "build:all": "electron-builder --win portable --mac dmg --linux AppImage"
  },
  "build": {
    "appId": "com.desktop-destroyer",
    "productName": "Desktop Destroyer",
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "howler": "^2.2.4",
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
